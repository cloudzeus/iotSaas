# Database Connection
# MySQL 8.0+ required. Format: mysql://user:password@host:port/database
DATABASE_URL="mysql://user:password@db-host:3306/dgsmart_hub"

# Auth.js v5 Configuration
# NEXTAUTH_URL must match deployment domain (e.g., https://app.dgsmart.gr)
NEXTAUTH_URL="https://app.dgsmart.gr"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-min-32-chars"

# Milesight LoRaWAN Developer Console API
# API tokens available at https://iotnet.milesight.com/console
MILESIGHT_API_URL="https://iotnet.milesight.com/api/v1"
MILESIGHT_API_TOKEN="your-milesight-api-token"
# Webhook signature verification secret (shared with Milesight webhook config)
MILESIGHT_WEBHOOK_SECRET="your-milesight-webhook-secret"

# Viva Wallet Payment Gateway
# Merchant credentials from https://www.vivapayments.com/merchant
VIVA_MERCHANT_ID="your-merchant-id"
VIVA_API_KEY="your-viva-api-key"
VIVA_WEBHOOK_SECRET="your-viva-webhook-secret"
VIVA_BASE_URL="https://api.vivapayments.com"

# Mailgun Email Service
# SMTP credentials for Mailgun (smtp.mailgun.org:587)
MAILGUN_API_KEY="your-mailgun-api-key"
MAILGUN_DOMAIN="mg.dgsmart.gr"
MAILGUN_FROM_EMAIL="noreply@dgsmart.gr"
MAILGUN_FROM_NAME="DGSmart Hub"

# SoftOne ERP Integration (Phase 5)
# Cloud-based ERP for invoice synchronization
SOFTONE_URL="https://your-subdomain.oncloud.gr"
SOFTONE_USERNAME="erp-integration-user"
SOFTONE_PASSWORD="erp-integration-password"
SOFTONE_APP_ID="2000"
SOFTONE_COMPANY="10"
SOFTONE_BRANCH="1000"
SOFTONE_MODULE="0"
SOFTONE_REFID="502"

# Cron endpoint authentication (any long random string)
CRON_SECRET="change-me-to-a-long-random-string"

# Application Configuration
# Public URL accessible from browsers
NEXT_PUBLIC_APP_URL="https://app.dgsmart.gr"
NEXT_PUBLIC_APP_NAME="DGSmart Hub"
